{
  "manifest_version": 3,
  "name": "FunPay Lists",
  "description": "Создание списков неподтвержденных заказов FunPay по анализу чатов.",
  "version": "2.6.4",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://funpay.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "FunPay Lists"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "popup.css",
        "popup.js"
      ],
      "matches": [
        "https://funpay.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://funpay.com/*"
      ],
      "js": [
        "ocr.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
