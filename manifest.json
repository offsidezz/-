{
"manifest_version": 3,
"name": "FunPay Lists",
"version": "4.0.1",
"description": "Автоматическая сортировка заказов FunPay по спискам с AI-классификацией",
"permissions": [
"activeTab",
"scripting",
"tabs",
"storage",
"notifications",
"alarms",
"clipboardWrite"
],
"host_permissions": [
"https://funpay.com/*"
],
"action": {
"default_popup": "popup.html",
"default_title": "FunPay Lists"
},
"background": {
"service_worker": "background.js"
},
"content_scripts": [
{
"matches": ["https://funpay.com/*"],
"js": ["content.js"],
"run_at": "document_idle"
}
]
}