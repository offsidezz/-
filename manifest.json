{
"manifest_version": 3,
"name": "FunPay Lists",
"description": "Создание списков неподтвержденных заказов FunPay по анализу чатов.",
"version": "3.0.1",
"permissions": [
"activeTab",
"scripting",
"tabs",
"storage",
"notifications",
"alarms"
],
"host_permissions": [
"https://funpay.com/*"
],
"background": {
"service_worker": "background.js"
},
"action": {
"default_title": "FunPay Lists",
"default_popup": "popup.html"
},
"web_accessible_resources": [
{
  "resources": [
    "popup.html",
    "popup.css",
    "popup.js"
  ],
  "matches": [
    "https://funpay.com/*"
  ]
}
],
"content_scripts": [
{
  "matches": [
    "https://funpay.com/*"
  ],
  "js": [
    "content.js"
  ],
  "run_at": "document_idle"
}
]
}