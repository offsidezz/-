{
"manifest_version": 3,
"name": "FunPay Lists",
"version": "3.1.0",
"description": "Автоматическая сортировка заказов FunPay по спискам с AI-классификацией",
"permissions": [
  "activeTab",
  "scripting",
  "tabs",
  "storage",
  "notifications",
  "alarms",
  "clipboardWrite"
],
"host_permissions": [
  "https://funpay.com/*"
],
"action": {
  "default_popup": "popup.html",
  "default_icon": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
},
"background": {
  "service_worker": "background.js"
},
"content_scripts": [
  {
    "matches": ["https://funpay.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }
],
"web_accessible_resources": [
  {
    "resources": ["icons/*.png"],
    "matches": ["https://funpay.com/*"]
  }
],
"icons": {
  "16": "icons/icon16.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
}
}