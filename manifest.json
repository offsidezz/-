{
"manifest_version": 3,
"name": "FunPay Lists",
"version": "3.2.0",
"description": "Автоматическая сортировка заказов FunPay по спискам с AI-классификацией",
"permissions": [
  "activeTab",
  "scripting",
  "tabs",
  "storage",
  "notifications",
  "alarms",
  "clipboardWrite",
  "sidePanel"
],
"host_permissions": [
  "https://funpay.com/*"
],
"action": {
  "default_title": "FunPay Lists"
},
"side_panel": {
  "default_path": "popup.html"
},
"background": {
  "service_worker": "background.js"
},
"content_scripts": [
  {
    "matches": ["https://funpay.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }
]
}